PORT=3000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cleancut
USER_JWT_SECRET=<your-user-jwt-secret>
ADMIN_JWT_SECRET=<your-admin-jwt-secret>
# Optional: separate refresh token secrets (defaults to JWT secret + ':refresh')
USER_REFRESH_SECRET=<your-user-refresh-secret>
ADMIN_REFRESH_SECRET=<your-admin-refresh-secret>
Cloudinary_NAME=<cloudinary-cloud-name>
Cloudinary_API_KEY=<cloudinary-api-key>
Cloudinary_API_SECRET=<cloudinary-api-secret>
# Comma-separated list of allowed frontend origins (required in production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
